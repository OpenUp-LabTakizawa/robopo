{
  "name": "robopo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "@robopo/*"
  ],
  "description": "Scoring and Calculation Application for Robosava",
  "keywords": [
    "auth.js",
    "biome",
    "bun",
    "docusaurus",
    "drrizzle",
    "nextjs",
    "react",
    "robosava",
    "tailwindcss",
    "typescript"
  ],
  "author": "Marukome <jambalaya.pyoncafe@gmail.com> (https://github.com/Marukome0743)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenUp-LabTakizawa/robopo"
  },
  "bugs": {
    "url": "https://github.com/OpenUp-LabTakizawa/robopo/issues"
  },
  "homepage": "https://openup-labtakizawa.github.io/robopo/",
  "scripts": {
    "dev": "bun --filter @robopo/web dev",
    "dev-win": "bun --filter @robopo/web dev-win",
    "build": "bun --filter @robopo/web build",
    "start": "bun --filter @robopo/web start",
    "docs-dev": "bun --filter @robopo/docs start",
    "docs-build": "bun --filter @robopo/docs build",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "lint:fix": "biome check --write",
    "test:unit": "bun --filter @robopo/web test:unit",
    "test:e2e": "bun --filter @robopo/web test:e2e",
    "test:report": "bun --filter @robopo/web test:report",
    "db:seed": "bun --filter @robopo/web db:seed",
    "setup-env": "bun run scripts/setup-env.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.3.13"
  }
}
